{
  "name": "la-limonariya",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --parallel -r --stream dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @limon/api db:generate",
    "db:migrate": "pnpm --filter @limon/api db:migrate",
    "up": "docker compose up -d --build",
    "down": "docker compose down"
  }
}
