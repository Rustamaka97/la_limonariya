{
  "name": "@limon/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
